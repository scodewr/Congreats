# -------------------------------------------------------
# Congreats — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores
# -------------------------------------------------------

# Banco de dados (usado pelo docker-compose para o serviço backend)
CONGREATS_DB_URL=jdbc:postgresql://postgres:5432/congreats
CONGREATS_DB_USER=congreats
CONGREATS_DB_PASSWORD=congreats

# JWT — TROQUE este valor em produção (mínimo 32 caracteres)
CONGREATS_JWT_SECRET=change-me-in-production-minimum-32-characters

# Modo de operação: WORLD (registro público) ou ENTERPRISE (IAM)
CONGREATS_MODE=WORLD

# Armazenamento de fotos (dentro do container)
CONGREATS_STORAGE_PATH=/deployments/uploads/photos
CONGREATS_STORAGE_BASE_URL=http://localhost:8080/files
